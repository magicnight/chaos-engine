# ╔══════════════════════════════════════════════╗
# ║  CHAOS Engine + NewsPredict — Production     ║
# ║  Copy to .env and configure before deploying ║
# ╚══════════════════════════════════════════════╝

# ── Domain (for Caddy auto HTTPS) ─────────────
# Set to your domain for production. Leave empty for HTTP-only.
DOMAIN=

# ── PostgreSQL ─────────────────────────────────
POSTGRES_PASSWORD=chaos_secret

# ── CHAOS Engine ───────────────────────────────
REFRESH_INTERVAL_MINUTES=15
SOURCE_TIMEOUT_SECS=30

# ── LLM (primary) ─────────────────────────────
LLM_PROVIDER=
LLM_API_KEY=
DEFAULT_MODEL=
SWEEP_LANG=en

# ── LLM (fallback) ────────────────────────────
FALLBACK_PROVIDER=
FALLBACK_MODEL=
GEMINI_API_KEY=

# ── LLM (local fallback) ──────────────────────
OLLAMA_URL=
OLLAMA_MODEL=

# ── Data Source Keys (optional) ────────────────
FRED_API_KEY=
FIRMS_MAP_KEY=
EIA_API_KEY=DEMO_KEY
WORLDNEWS_API_KEY=
ACLED_EMAIL=
ACLED_PASSWORD=

# ── Telegram Bot ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=5000

# ── Discord Bot ────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

# ── NewsPredict ────────────────────────────────
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production
CRON_SECRET=change-this-too
NEXT_PUBLIC_CHAOS_URL=

# ── NewsPredict Web3 ──────────────────────────
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_ANKR_API_KEY=
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_CHAOS_TOKEN_TESTNET=0x96be44c3CC84C05B76db83c18bd3d7bA538a433d
NEXT_PUBLIC_MARKET_CONTRACT_TESTNET=0x244d85a0a174Ef420AF1b7133c475219C3e9429b
NEXT_PUBLIC_CHAOS_TOKEN_MAINNET=0xcE3fbb08D72BEd7F645F59FE0f031659b5B298c4
NEXT_PUBLIC_MARKET_CONTRACT_MAINNET=0xAa7208Cf64078756fB58698fbE748DC3c9b4Cb88

# ── Redis (optional, for caching) ──────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Notifications ──────────────────────────────
WEBHOOK_URL=

# ── Watchlist ──────────────────────────────────
WATCH_REGIONS=
ALERT_KEYWORDS=
WATCH_TICKERS=
