{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaos.dev/schemas/market-seed.json",
  "title": "MarketSeed",
  "description": "Schema for a prediction market seed generated by CHAOS.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "question": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["geopolitics", "economics", "science", "technology", "health", "environment", "sports", "entertainment", "politics", "other"]
    },
    "options": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "resolution_criteria": { "type": "string" },
    "resolution_source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "context": { "type": "string" },
    "suggested_end_time": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "question", "category", "options", "resolution_criteria", "confidence"]
}
