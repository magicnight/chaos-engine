# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# CHAOS API
CHAOS_API_URL=http://localhost:3117
CHAOS_API_KEY=your-chaos-api-key

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Web3 / Reown
NEXT_PUBLIC_REOWN_PROJECT_ID=your-reown-project-id

# BSC Contracts (set after deployment)
NEXT_PUBLIC_CRUX_TOKEN_TESTNET=
NEXT_PUBLIC_MARKET_CONTRACT_TESTNET=
NEXT_PUBLIC_CRUX_TOKEN_MAINNET=
NEXT_PUBLIC_MARKET_CONTRACT_MAINNET=
DEPLOYER_PRIVATE_KEY=
